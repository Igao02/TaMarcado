@page "/register"
@rendermode InteractiveServer
@inherits IndexPageBase

<PageTitle>Cadastro — TaMarcado</PageTitle>

<div class="register-page">
    <MudGrid Justify="Justify.Center" Style="min-height: 100vh; align-items: center; background: var(--mud-palette-background);">
        <MudItem xs="12" sm="8" md="6" lg="5">
            <MudPaper Class="register-card" Elevation="0" Style="border-radius: 32px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;" Outlined="true">
                <div class="card-gradient"></div>
                <MudCardContent Class="pa-6 pa-sm-8">
                    <div class="text-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="background: linear-gradient(135deg, var(--mud-palette-primary), var(--mud-palette-secondary)); color: transparent;">
                            Criar conta
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Inherit" Class="mt-2 opacity-70">
                            Comece a gerenciar seus agendamentos
                        </MudText>
                    </div>

                    <MudText Typo="Typo.subtitle2" Class="mb-2">Tipo de conta</MudText>
                    <MudButtonGroup OverrideStyles="false" Class="mb-4 d-flex" FullWidth="true">
                        <MudButton Variant="@(model.Role == "Profissional" ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="@(() => model.Role = "Profissional")"
                                   StartIcon="@Icons.Material.Filled.Work">
                            Profissional
                        </MudButton>
                        <MudButton Variant="@(model.Role == "Cliente" ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="@(() => model.Role = "Cliente")"
                                   StartIcon="@Icons.Material.Filled.Person">
                            Cliente
                        </MudButton>
                    </MudButtonGroup>

                    @if (errorMessage is not null)
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4 rounded-xl" Dense="false" Icon="@Icons.Material.Filled.ErrorOutline">
                            @errorMessage
                        </MudAlert>
                    }

                    <EditForm Model="model" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />

                        <MudTextField @bind-Value="model.Email"
                                      Label="E-mail"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Class="mb-4"
                                      For="@(() => model.Email)"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email"
                                      AdornmentColor="Color.Primary" />

                        <MudTextField @bind-Value="model.Password"
                                      Label="Senha"
                                      InputType="@(showPassword ? InputType.Text : InputType.Password)"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Class="mb-4"
                                      For="@(() => model.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="() => showPassword = !showPassword"
                                      AdornmentColor="Color.Default" />

                        <MudTextField @bind-Value="confirmPassword"
                                      Label="Confirmar senha"
                                      InputType="@(showConfirmPassword ? InputType.Text : InputType.Password)"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Class="mb-4"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="() => showConfirmPassword = !showConfirmPassword"
                                      AdornmentColor="Color.Default" />

                        <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-6">
                            <MudCheckBox @bind-Value="model.AceitoTermos"
                                         Label=""
                                         For="@(() => model.AceitoTermos)"
                                         Size="Size.Small" />
                            <MudText Typo="Typo.body2">
                                Aceito os <MudLink Href="/termos" Target="_blank">termos de uso</MudLink> e <MudLink Href="/privacidade" Target="_blank">política de privacidade</MudLink>
                            </MudText>
                        </div>

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   Disabled="isLoading"
                                   Class="rounded-pill text-capitalize font-weight-bold"
                                   Style="height: 48px;">
                            @if (isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Color="Color.Inherit" />
                            }
                            Cadastrar
                        </MudButton>
                    </EditForm>

                    <MudDivider Class="my-6" />

                    <div class="text-center">
                        <MudText Typo="Typo.body2" Align="Align.Center">
                            Já tem uma conta?
                            <MudLink Href="/login" Style="font-weight: 600; text-decoration: none;">Entrar agora</MudLink>
                        </MudText>
                    </div>

                    <div class="text-center mt-4">
                        <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Inherit" Style="opacity: 0.6;">
                            Ao se cadastrar, você concorda com nossos termos
                        </MudText>
                    </div>
                </MudCardContent>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

