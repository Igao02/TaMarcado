@page "/register"
@rendermode InteractiveServer
@inherits IndexPageBase

<PageTitle>Cadastro — TaMarcado</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height:100vh;align-items:center">
    <MudItem xs="12" sm="8" md="5" lg="4">
        <MudCard Elevation="4">
            <MudCardContent Class="pa-8">
                <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">Criar conta</MudText>

                @if (erro is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@erro</MudAlert>
                }

                <EditForm Model="model" OnValidSubmit="Registrar">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="model.Email"
                                  Label="E-mail"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="mb-4"
                                  For="@(() => model.Email)" />

                    <MudTextField @bind-Value="model.Password"
                                  Label="Senha"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="mb-4"
                                  For="@(() => model.Password)" />

                    <MudCheckBox @bind-Value="model.AceitoTermos"
                                 Label="Aceito os termos de uso"
                                 Class="mb-6"
                                 For="@(() => model.AceitoTermos)" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="isLoading">
                        @if (isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Cadastrar
                    </MudButton>
                </EditForm>

                <MudText Align="Align.Center" Class="mt-4">
                    Já tem conta?
                    <MudLink Href="/login">Entrar</MudLink>
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>