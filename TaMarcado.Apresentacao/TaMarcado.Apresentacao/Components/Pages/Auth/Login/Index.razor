@page "/login"

<PageTitle>Entrar — TaMarcado</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height:100vh;align-items:center">
    <MudItem xs="12" sm="8" md="5" lg="4">
        <MudCard Elevation="4">
            <MudCardContent Class="pa-8">
                <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">Entrar</MudText>

                @if (CadastroParam == "1")
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4">
                        Conta criada com sucesso! Faça login para continuar.
                    </MudAlert>
                }

                @if (ErroParam == "1")
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">
                        E-mail ou senha inválidos.
                    </MudAlert>
                }

                <form method="post" action="/auth/login">
                    <MudTextField T="string"
                                  Name="email"
                                  Label="E-mail"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="mb-4" />

                    <MudTextField T="string"
                                  Name="password"
                                  Label="Senha"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="mb-6" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large">
                        Entrar
                    </MudButton>
                </form>

                <MudText Align="Align.Center" Class="mt-4">
                    Não tem conta?
                    <MudLink Href="/register">Cadastre-se</MudLink>
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery(Name = "erro")]
    private string? ErroParam { get; set; }

    [SupplyParameterFromQuery(Name = "cadastro")]
    private string? CadastroParam { get; set; }
}
