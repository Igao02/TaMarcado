@page "/horarios"
@rendermode InteractiveServer
@inherits HorariosPageBase
@attribute [Authorize]

<PageTitle>Horários — TaMarcado</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <MudText Typo="Typo.h5" Style="margin-top: 20px;" Class="font-weight-bold">Horários Disponíveis</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenDialog"
               Class="rounded-pill">
        Novo horário
    </MudButton>
</div>

@if (_errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4 rounded-xl" Dense="true">
        @_errorMessage
    </MudAlert>
}

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_horarios.Count == 0)
{
    <MudPaper Class="pa-8" Elevation="1" Style="border-radius: 16px; text-align: center;">
        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
        <MudText Typo="Typo.h6" Color="Color.Secondary">Nenhum horário cadastrado</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">Clique em "Novo horário" para definir sua disponibilidade</MudText>
    </MudPaper>
}
else
{
    <MudPaper Elevation="1" Style="border-radius: 16px; overflow: hidden;">
        <MudTable Items="_horarios" Hover="true" Dense="true" Striped="false" Elevation="0">
            <HeaderContent>
                <MudTh>Dia da semana</MudTh>
                <MudTh>Início</MudTh>
                <MudTh>Fim</MudTh>
                <MudTh>Status</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Dia da semana">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.WeekDayName</MudText>
                </MudTd>
                <MudTd DataLabel="Início">@context.StartTime</MudTd>
                <MudTd DataLabel="Fim">@context.EndTime</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(context.Active ? Color.Success : Color.Default)" Size="Size.Small">
                        @(context.Active ? "Ativo" : "Inativo")
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => HandleDelete(context.Id))"
                                   Disabled="_deletingId == context.Id" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

<HorarioFormDialog @bind-Visible="_dialogOpen"
                   OnSaved="LoadHorarios" />
